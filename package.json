  "description": "Provider-agnostic mail processing runtime for OpenClaw — rule engine, action registry, and dispatch pipeline",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
